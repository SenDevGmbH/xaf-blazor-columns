<?xml version="1.0" encoding="utf-8"?>
<Application Title="SenDev.Xaf.Blazor.Columns.Demo">
	<Options>
		<LayoutManagerOptions RequiredFieldMark="*" />
	</Options>
	<SchemaModules>
		<SchemaModule Name="SystemModule" Version="25.2.6.0" IsNewNode="True" />
	</SchemaModules>
	<Views>
		<ListView Id="TreeListColumnPixelSample_ListView" MasterDetailMode="ListViewAndDetailView" MasterDetailView="TreeListColumnPixelSample_DetailView">
			<Columns ColumnWidthMode="1">
				<ColumnInfo Id="Parent" Width="90" Index="-1" Removed="True" />
				<ColumnInfo Id="PercentComplete" Width="183" Index="-1" Removed="True" />
				<ColumnInfo Id="Name" Width="200" MaxLength="200" />
				<ColumnInfo Id="StartDate" Width="100" />
				<ColumnInfo Id="DueDate" Width="90" />
				<ColumnInfo Id="Description" Width="220" Index="3" />
				<ColumnInfo Id="Oid" Removed="True" />
			</Columns>
		</ListView>
		<ListView Id="TreeListColumnProportionalSample_ListView" MasterDetailMode="ListViewAndDetailView" MasterDetailView="TreeListColumnProportionalSample_DetailView">
			<Columns ColumnWidthMode="2">
				<ColumnInfo Id="Parent" Width="90" Index="-1" Removed="True" />
				<ColumnInfo Id="PercentComplete" Width="183" Index="-1" Removed="True" />
				<ColumnInfo Id="Name" Width="200" MaxLength="200" />
				<ColumnInfo Id="StartDate" Width="100" />
				<ColumnInfo Id="DueDate" Width="90" />
				<ColumnInfo Id="Description" Width="220" Index="3" />
				<ColumnInfo Id="Oid" Removed="True" />
			</Columns>
		</ListView>
		<ListView Id="GridColumnPixelSample_ListView">
			<Columns ColumnWidthMode="1">
				<ColumnInfo Id="Title" Width="230" />
				<ColumnInfo Id="Owner" Width="120" />
				<ColumnInfo Id="Phase" Width="130" />
				<ColumnInfo Id="StartDate" Width="110" />
				<ColumnInfo Id="DueDate" Width="110" />
				<ColumnInfo Id="Priority" Width="80" />
				<ColumnInfo Id="EstimatedCost" Width="130" />
				<ColumnInfo Id="Blocked" Width="90" />
				<ColumnInfo Id="Notes" Width="320" />
				<ColumnInfo Id="Oid" Removed="True" />
			</Columns>
		</ListView>
		<ListView Id="GridColumnProportionalSample_ListView">
			<Columns ColumnWidthMode="2">
				<ColumnInfo Id="Title" Width="260" />
				<ColumnInfo Id="Account" Width="150" />
				<ColumnInfo Id="Region" Width="130" />
				<ColumnInfo Id="ReportDate" Width="110" />
				<ColumnInfo Id="ItemCount" Width="90" />
				<ColumnInfo Id="Revenue" Width="130" />
				<ColumnInfo Id="Margin" Width="90" />
				<ColumnInfo Id="Reviewed" Width="90" />
				<ColumnInfo Id="Comment" Width="330" />
				<ColumnInfo Id="Oid" Removed="True" />
			</Columns>
		</ListView>
	</Views>
</Application>
